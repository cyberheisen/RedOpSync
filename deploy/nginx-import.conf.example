# Example for API location when using large import uploads (e.g. GoWitness ZIP ~130MB).
# Include or merge into your server { ... } block.
# proxy_read_timeout must be long enough for the server to finish processing (extract, import);
# 600s (10 min) is recommended for very large zips.

location /api/ {
    client_max_body_size 200m;
    proxy_connect_timeout 300s;
    proxy_send_timeout 600s;
    proxy_read_timeout 600s;

    proxy_pass http://api_upstream;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
